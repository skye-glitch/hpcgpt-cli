{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "enabled_providers": ["ncsahosted"],
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
  },
  "mode": {
    "support": {
      "model": "ncsahosted/Qwen/Qwen3-VL-32B-Instruct",
      "prompt": "{file:./prompts/support.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "provider": {
    "ncsahosted": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NCSA Hosted",
      "options": {
        "baseURL": "{env:NCSA_LLM_URL}"
      },
      "models": {
        "Qwen/Qwen3-VL-32B-Instruct": {
          "name": "Qwen 3 32B Instruct",
          "options": {
            "stream": true
          }
        }
      }
    }
  },
  "mcp": {
    "slurm-mcp-server": {
      "type": "remote",
      "url": "http://dt-hpcgpt:8001/mcp",
      "enabled": true
    },
    "illinois-chat-server": {
      "type": "remote", 
      "url": "http://dt-hpcgpt:8002/mcp",
      "enabled": true
    },
    "report-server": {
      "type": "remote",
      "url": "http://dt-hpcgpt:8003/mcp", 
      "enabled": true
    },
    "knowledge-base-server": {
      "type": "remote",
      "url": "http://dt-hpcgpt:8004/mcp",
      "enabled": true
    }
  },
  "command": {
    "report": {
      // Description shown in the TUI
      "template": "{file:./prompts/report.txt}",
      "description": "Report an issue to the Delta support team",
      "agent": "support",
      "model": "ncsahosted/Qwen/Qwen3-VL-32B-Instruct"
    }
  },
  // I'm disabling sharing as i don't think this is a feature we want on Delta
  "share": "disabled",
  // Configure permissions to control what AI agents can do by default.
  "permission": {
    "edit": "ask",
    "bash": "ask"
  }
}
